# ═══════════════════════════════════════════════════
# Aman Bhaskar Portfolio — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file:  cp .env.example .env.local
# Then fill in your values below.

# ─── Ollama (Local AI) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── GitHub (optional — enables repo ingestion) ───
GITHUB_TOKEN=
GITHUB_USERNAME=aman-bhaskar-codes

# ─── NextAuth (optional — for admin panel) ────────
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000
