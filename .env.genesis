# ═══════════════════════════════════════════════════════════
# ANTIGRAVITY OS v4 — Environment Template
# ═══════════════════════════════════════════════════════════
# INSTRUCTIONS:
#   1. Copy this file: cp .env.genesis .env
#   2. Generate all secrets: openssl rand -hex 32
#   3. Fill in API tokens
#   4. NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ── OWNER IDENTITY ─────────────────────────────────────────
OWNER_NAME=Aman Bhaskar
OWNER_TITLE=Software Engineer & AI Builder
OWNER_BIO=Building AI systems that are resilient, local-first, and production-grade.

# ── DATABASE (PostgreSQL + pgvector) ───────────────────────
POSTGRES_PASSWORD=            # REQUIRED — generate with: openssl rand -base64 24
POSTGRES_USER=postgres
POSTGRES_DB=portfolio_db

# ── REDIS ──────────────────────────────────────────────────
# Redis URLs are configured in docker-compose.yml (redis_cache + redis_persistent)

# ── QDRANT ─────────────────────────────────────────────────
QDRANT_COLLECTION_KNOWLEDGE=portfolio_knowledge
QDRANT_COLLECTION_MEMORIES=user_memories

# ── OLLAMA ─────────────────────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT=120
EMBED_MODEL=nomic-embed-text

# ── LLM MODEL ROUTING ─────────────────────────────────────
LLM_MODEL_HEAVY=phi4-mini
LLM_MODEL_MEDIUM=llama3.2:3b
LLM_MODEL_LIGHT=qwen2.5:3b
OLLAMA_VISION_MODEL=llava-phi3
OLLAMA_RERANK_MODEL=mxbai-rerank-large

# ── SECRETS (ALL REQUIRED — generate each with: openssl rand -hex 32) ──
JWT_SECRET=                   # REQUIRED
VAULT_ENCRYPTION_KEY=         # REQUIRED
ADMIN_KEY=                    # REQUIRED — used to protect admin API endpoints
NEXTAUTH_SECRET=              # REQUIRED — used by Next.js auth
SECRET_KEY=                   # REQUIRED — general app secret

# ── GITHUB ─────────────────────────────────────────────────
GITHUB_TOKEN=                 # Fine-grained PAT with read-only repo access
GITHUB_USERNAME=aman-bhaskar-codes
GITHUB_WEBHOOK_SECRET=        # generate with: openssl rand -hex 20

# ── MINIO (S3 Storage) ────────────────────────────────────
MINIO_ACCESS_KEY=             # REQUIRED — no defaults, service fails if unset
MINIO_SECRET_KEY=             # REQUIRED — generate with: openssl rand -base64 24

# ── LANGFUSE (LLM Observability) ──────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_NEXTAUTH_SECRET=     # REQUIRED — generate with: openssl rand -hex 32
LANGFUSE_SALT=                # REQUIRED — generate with: openssl rand -hex 16

# ── GRAFANA ────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=       # REQUIRED — generate with: openssl rand -base64 24

# ── UMAMI (Analytics) ─────────────────────────────────────
UMAMI_APP_SECRET=             # REQUIRED — generate with: openssl rand -hex 32
UMAMI_TRACKING_ID=

# ── NTFY ───────────────────────────────────────────────────
NTFY_BASE_URL=http://ntfy:80
NTFY_TOPIC=antigravity-alerts

# ── RATE LIMITS ────────────────────────────────────────────
RATE_LIMIT_ANON_PER_MIN=20
RATE_LIMIT_AUTH_PER_MIN=60

# ── FEATURE FLAGS ──────────────────────────────────────────
FEATURE_VOICE_MODE=true
FEATURE_COLBERT_RETRIEVAL=true
FEATURE_DSPY_OPTIMIZATION=true
FEATURE_3D_CONSTELLATION=true
FEATURE_PWA=true

# ── RUNTIME ────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
