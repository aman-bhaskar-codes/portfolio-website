# ANTIGRAVITY OS v4 — Environment Template
# Copy to .env and fill in your values. Never commit .env.

# ── OWNER IDENTITY ─────────────────────────────────────────────
OWNER_NAME=Aman Bhaskar
OWNER_TITLE=Software Engineer & AI Builder
OWNER_BIO=Building AI systems that are resilient, local-first, and production-grade.

# ── DATABASE (PostgreSQL + pgvector) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://antigravity:strong_password_here@postgres:5432/antigravity
SYNC_DATABASE_URL=postgresql://antigravity:strong_password_here@postgres:5432/antigravity
POSTGRES_USER=antigravity
POSTGRES_PASSWORD=strong_password_here
POSTGRES_DB=antigravity

# ── REDIS ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── QDRANT ─────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_KNOWLEDGE=portfolio_knowledge
QDRANT_COLLECTION_MEMORIES=user_memories

# ── OLLAMA ─────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_TIMEOUT=120
EMBED_MODEL=nomic-embed-text

# ── LLM MODEL ROUTING ─────────────────────────────────────────
LLM_MODEL_HEAVY=phi4-mini
LLM_MODEL_MEDIUM=llama3.2:3b
LLM_MODEL_LIGHT=qwen2.5:3b
OLLAMA_VISION_MODEL=llava-phi3
OLLAMA_RERANK_MODEL=mxbai-rerank-large

# ── SECRETS (generate: openssl rand -hex 32) ───────────────────
JWT_SECRET=changeme_generate_32_byte_hex
VAULT_ENCRYPTION_KEY=changeme_generate_another_32_byte_hex

# ── GITHUB ─────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_USERNAME=aman-bhaskar-codes
GITHUB_WEBHOOK_SECRET=changeme_random_secret

# ── MINIO ──────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_this
MINIO_BUCKET_BRIEFS=portfolio-briefs

# ── LANGFUSE ───────────────────────────────────────────────────
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── NTFY ───────────────────────────────────────────────────────
NTFY_BASE_URL=http://ntfy:80
NTFY_TOPIC=antigravity-alerts

# ── RATE LIMITS ────────────────────────────────────────────────
RATE_LIMIT_ANON_PER_MIN=20
RATE_LIMIT_AUTH_PER_MIN=60

# ── FEATURE FLAGS ──────────────────────────────────────────────
FEATURE_VOICE_MODE=true
FEATURE_COLBERT_RETRIEVAL=true
FEATURE_DSPY_OPTIMIZATION=true
FEATURE_3D_CONSTELLATION=true
FEATURE_PWA=true

# ── RUNTIME ────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
