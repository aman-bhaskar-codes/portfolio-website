# ─── Next.js Development Container ───
# Isolates node_modules and .next inside the container,
# preventing iCloud sync locks while enabling hot-reload.

FROM node:20-alpine

WORKDIR /app

# Install dependencies and Prisma targets together
COPY package.json package-lock.json ./
COPY prisma ./prisma
ENV PRISMA_CLIENT_ENGINE_TYPE=binary
RUN npm ci --legacy-peer-deps

# Copy application source (hot-reload watches these via bind mount)
COPY . .

EXPOSE 3334

# Generate Prisma Client dynamically at runtime to avoid Alpine/macOS architecture clashes, then boot Next.js
CMD ["sh", "-c", "npx prisma generate && npm run dev"]
